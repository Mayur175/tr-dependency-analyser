# EditorConfig — keeps formatting consistent across editors / OSes
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# ABAP files — ABAP convention is 2-space indent, no tabs
[*.abap]
indent_size = 2

# Java (Eclipse plugin)
[*.java]
indent_size = 4

# Maven, Manifest, plugin.xml — keep 2 spaces
[{*.xml,pom.xml,MANIFEST.MF,plugin.xml,feature.xml,category.xml}]
indent_size = 2

# Python (when added)
[*.py]
indent_size = 4

# Markdown — preserve trailing whitespace (intentional line breaks)
[*.md]
trim_trailing_whitespace = false

# Makefiles require tabs
[Makefile]
indent_style = tab
