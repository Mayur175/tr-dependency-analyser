# Environment variable template — TR Dependency Analyser
#
# Copy this file to `.env` (which is gitignored) and fill in the values
# for your local environment. The TR Dependency Analyser itself does not
# currently consume any environment variables — this template covers the
# Phase 4 BTP webhook service (when implemented) and any developer-side
# tooling.
#
# ===========================================================================
# Phase 4 — GitHub PR Status Check (BTP CF / Kyma webhook service)
# ===========================================================================

# GitHub App / PAT used to post Check-Runs back to the repo.
# Scopes required: `checks:write`, `contents:read`, `pull_requests:read`.
GITHUB_TOKEN=

# Webhook secret shared with the GitHub repository's webhook config.
# Used to verify `X-Hub-Signature-256` on incoming payloads.
GITHUB_WEBHOOK_SECRET=

# SAP system the webhook service should call to invoke the analyzer.
SAP_SYSTEM_URL=https://your-system.example.com:44300
SAP_USERNAME=
SAP_PASSWORD=

# ===========================================================================
# Eclipse plugin development (optional)
# ===========================================================================

# Eclipse install location, used by `mvn install` to publish locally during
# development. Leave blank to use the Tycho default.
ECLIPSE_INSTALL=

# ===========================================================================
# CI / GitHub Actions (consumed only by workflows)
# ===========================================================================

# Set in GitHub Secrets, not in your local `.env`. Listed here for visibility.
# PAGES_DEPLOY_TOKEN=
