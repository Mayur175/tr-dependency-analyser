<?xml version="1.0" encoding="utf-8"?>
<!--
  abapGit repository descriptor for the TR Analyser ABAP backend.

  Reference: https://docs.abapgit.org/ref-dot-abapgit.html

  STARTING_FOLDER  /src/      - all SAP objects live under abap/src/
  FOLDER_LOGIC     FULL       - flat layout (one package = one folder)
  MAIN_LANGUAGE    E          - English
  IGNORE list keeps documentation, plan files, and the Eclipse-side code
                                 outside the repository when it is cloned
                                 onto the SAP system.

  How to use on the SAP side:
    1. Open transaction ZABAPGIT (or run abapGit programmatically).
    2. New Online Repository -> URL of this Git repository.
    3. Choose target package (e.g. ZGCTS) and a workbench TR for the import.
    4. Pull -> activate.

  How to install abapGit itself (once per system):
    https://docs.abapgit.org/guide-install.html
-->
<asx:abap xmlns:asx="http://www.sap.com/abapxml" version="1.0">
  <asx:values>
    <DATA>
      <MASTER_LANGUAGE>E</MASTER_LANGUAGE>
      <STARTING_FOLDER>/src/</STARTING_FOLDER>
      <FOLDER_LOGIC>FULL</FOLDER_LOGIC>
      <IGNORE>
        <item>/.gitignore</item>
        <item>/LICENSE</item>
        <item>/README.md</item>
        <item>/docs/</item>
      </IGNORE>
    </DATA>
  </asx:values>
</asx:abap>