<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

  <!-- =====================================================================
       1. COMMAND DEFINITIONS
       ===================================================================== -->
  <extension point="org.eclipse.ui.commands">
    <command
        id="com.gmw.gcts.analyzer.commands.analyzeTR"
        name="TR Analyser"
        description="Analyse Transport Request / Task dependencies and recommend a safe release order"/>
    <command
        id="com.gmw.gcts.analyzer.commands.checkForUpdates"
        name="TR Analyser - Check for Updates"
        description="Check the TR Analyser update site for a newer version"/>
  </extension>

  <!-- =====================================================================
       2. HANDLER BINDINGS
       ===================================================================== -->
  <extension point="org.eclipse.ui.handlers">
    <handler
        commandId="com.gmw.gcts.analyzer.commands.analyzeTR"
        class="com.gmw.gcts.analyzer.handlers.AnalyzeTRHandler"/>
    <handler
        commandId="com.gmw.gcts.analyzer.commands.checkForUpdates"
        class="com.gmw.gcts.analyzer.handlers.CheckForUpdatesHandler"/>
  </extension>

  <!-- =====================================================================
       3. MENUS - context menu + top-level menu bar + toolbar
       ===================================================================== -->
  <extension point="org.eclipse.ui.menus">

    <!-- Generic right-click context menu (works in Project Explorer,
         Transport Organizer tree, etc.) -->
    <menuContribution allPopups="true"
        locationURI="popup:org.eclipse.ui.popup.any?after=additions">
      <command commandId="com.gmw.gcts.analyzer.commands.analyzeTR"
               label="TR Analyser..."
               icon="icons/dependency.png"
               tooltip="Analyse cross-task / cross-TR dependencies">
        <visibleWhen checkEnabled="false">
          <with variable="selection">
            <count value="+"/>
          </with>
        </visibleWhen>
      </command>
    </menuContribution>

    <!-- Top-level menu bar -->
    <menuContribution locationURI="menu:org.eclipse.ui.main.menu?after=additions">
      <menu id="com.gmw.gcts.analyzer.menu"
            label="TR Analyser"
            mnemonic="T">
        <command commandId="com.gmw.gcts.analyzer.commands.analyzeTR"
                 label="TR Analyser..."
                 icon="icons/dependency.png"/>
        <separator name="com.gmw.gcts.analyzer.menu.sep1"
                   visible="true"/>
        <command commandId="com.gmw.gcts.analyzer.commands.checkForUpdates"
                 label="Check for Updates..."
                 tooltip="Pull the latest TR Analyser version from the update site"/>
      </menu>
    </menuContribution>

    <!-- Main toolbar button -->
    <menuContribution locationURI="toolbar:org.eclipse.ui.main.toolbar?after=additions">
      <toolbar id="com.gmw.gcts.analyzer.toolbar">
        <command commandId="com.gmw.gcts.analyzer.commands.analyzeTR"
                 icon="icons/dependency.png"
                 tooltip="TR Analyser (Ctrl+Alt+G)"/>
      </toolbar>
    </menuContribution>

  </extension>

  <!-- =====================================================================
       4. KEYBOARD SHORTCUT  M1+M3+G  (Ctrl+Alt+G on Win/Linux, Cmd+Alt+G on Mac)
       ===================================================================== -->
  <extension point="org.eclipse.ui.bindings">
    <key commandId="com.gmw.gcts.analyzer.commands.analyzeTR"
         sequence="M1+M3+G"
         schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
         contextId="org.eclipse.ui.contexts.window"/>
  </extension>

  <!-- =====================================================================
       5. VIEW - structured table view (clusters, edges, pull order)
       ===================================================================== -->
  <extension point="org.eclipse.ui.views">

    <category
        id="com.gmw.gcts.analyzer.viewCategory"
        name="TR Analyser"/>

    <view
        id="com.gmw.gcts.analyzer.views.dependencyResult"
        name="TR Analyser"
        class="com.gmw.gcts.analyzer.views.DependencyResultView"
        category="com.gmw.gcts.analyzer.viewCategory"
        icon="icons/dependency.png"
        restorable="true"
        allowMultiple="false"/>

  </extension>

  <!-- =====================================================================
       6. PREFERENCES PAGE
       ===================================================================== -->
  <extension point="org.eclipse.ui.preferencePages">
    <page
        id="com.gmw.gcts.analyzer.preferences"
        name="TR Analyser"
        class="com.gmw.gcts.analyzer.preferences.AnalyzerPreferencePage">
    </page>
  </extension>

</plugin>